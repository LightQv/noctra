NOCTRA_CONFIG_POLICY=customizable
NOCTRA_DOCS_BASE_PATH=https://github.com/LightQv/noctra/blob/main
NOCTRA_CHROME_EXTENSIONS_LICENSE=GPL-3.0

# CI-only: disables the Chromium sandbox entirely for Electron smoke tests.
# Required on headless Linux runners (e.g., GitHub Actions) where AppArmor
# blocks both setuid and namespace sandboxes.
# Local development should leave this unset to keep full sandboxing.
CI_NO_SANDBOX=
