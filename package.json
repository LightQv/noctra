{
  "name": "noctra",
  "productName": "Noctra",
  "version": "0.1.0",
  "description": "A keyboard-first browser shell with a Neovim-style workflow.",
  "author": "LightQv",
  "license": "MIT",
  "homepage": "https://github.com/LightQv/noctra",
  "repository": {
    "type": "git",
    "url": "https://github.com/LightQv/noctra.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"**/*.{md,json,yml,yaml}\" --write",
    "format:check": "prettier \"**/*.{md,json,yml,yaml}\" --check",
    "check:intents": "node scripts/check-intents-parity.js",
    "check:state-ownership": "node scripts/check-state-ownership.js",
    "check:security-baseline": "node scripts/check-security-baseline.js",
    "check:deps-locked": "node scripts/check-dependency-versions.js",
    "test": "node --test",
    "test:app": "node scripts/run-tests.js tests/app",
    "test:security": "node scripts/run-tests.js tests/security",
    "test:guardrails": "node scripts/run-tests.js tests/guardrails",
    "test:keymap": "node --test tests/app/grammar-keymap-conflicts.test.js tests/app/config-schema-keymap.test.js",
    "test:smoke": "node tests/smoke/electron-startup.smoke.js",
    "test:smoke:overlay": "node tests/smoke/electron-overlay-panel-split.smoke.js",
    "test:smoke:ui-cadence": "node tests/smoke/electron-ui-cadence.smoke.js",
    "test:smoke:security": "node tests/smoke/electron-security-boundary.smoke.js",
    "test:smoke:settings-lifecycle": "node tests/smoke/electron-settings-lifecycle.smoke.js",
    "test:smoke:devtools-lifecycle": "node tests/smoke/electron-devtools-lifecycle.smoke.js",
    "test:smoke:session-lifecycle": "node tests/smoke/electron-session-lifecycle.smoke.js",
    "test:smoke:focus-lifecycle": "node tests/smoke/electron-focus-lifecycle.smoke.js",
    "ci:test": "npm run lint && npm run format:check && npm run check:intents && npm run check:state-ownership && npm run check:security-baseline && npm run check:deps-locked && npm test && npm run test:smoke && npm run test:smoke:overlay && npm run test:smoke:ui-cadence && npm run test:smoke:security && npm run test:smoke:settings-lifecycle && npm run test:smoke:devtools-lifecycle && npm run test:smoke:session-lifecycle && npm run test:smoke:focus-lifecycle",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.1",
    "@electron-forge/maker-deb": "7.11.1",
    "@electron-forge/maker-dmg": "7.11.1",
    "@electron-forge/maker-rpm": "7.11.1",
    "@electron-forge/maker-squirrel": "7.11.1",
    "@electron-forge/maker-zip": "7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "7.11.1",
    "@electron-forge/plugin-fuses": "7.11.1",
    "@electron/fuses": "1.8.0",
    "@eslint/js": "9.39.4",
    "electron": "41.2.2",
    "eslint": "9.39.4",
    "globals": "17.6.0",
    "prettier": "3.8.3"
  },
  "dependencies": {
    "codemirror": "5.65.16",
    "dotenv": "17.4.2",
    "electron-squirrel-startup": "1.0.1",
    "yaml": "2.8.3"
  }
}
